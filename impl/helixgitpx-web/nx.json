{
  "$schema": "./node_modules/nx/schemas/nx-schema.json",
  "namedInputs": {
    "default": ["{projectRoot}/**/*", "sharedGlobals"],
    "production": ["default", "!{projectRoot}/**/*.spec.ts"],
    "sharedGlobals": []
  },
  "targetDefaults": {
    "build":  { "cache": true, "dependsOn": ["^build"] },
    "lint":   { "cache": true },
    "test":   { "cache": true }
  },
  "defaultBase": "origin/main"
}
