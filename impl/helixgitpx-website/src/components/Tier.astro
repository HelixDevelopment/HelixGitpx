---
interface Props {
  name: string;
  price: string;
  per: string;
  desc: string;
  features: string[];
  cta: string;
  href: string;
  featured?: boolean;
}
const { name, price, per, desc, features, cta, href, featured } = Astro.props as Props;
const border = featured ? 'border-primary shadow-xl' : 'border-slate-200';
const button = featured ? 'bg-primary text-white hover:bg-blue-700' : 'border border-slate-300 hover:border-primary';
---
<div class={`rounded-2xl border p-8 ${border}`}>
  {featured && <div class="mb-3 text-xs font-medium text-primary uppercase tracking-wider">Most popular</div>}
  <div class="text-lg font-semibold">{name}</div>
  <div class="mt-3 flex items-baseline gap-1">
    <span class="text-4xl font-semibold">{price}</span>
    <span class="text-sm text-slate-500">{per}</span>
  </div>
  <p class="mt-2 text-sm text-slate-600">{desc}</p>
  <ul class="mt-6 space-y-2 text-sm">
    {features.map((f) => (
      <li class="flex gap-2"><span class="text-success">✓</span><span>{f}</span></li>
    ))}
  </ul>
  <a href={href} class={`mt-8 block rounded px-4 py-2 text-center text-sm font-medium ${button}`}>{cta}</a>
</div>
