---
import BaseLayout from '../layouts/BaseLayout.astro';

const providers = [
  'GitHub', 'GitLab', 'Gitea', 'Gitee', 'Bitbucket', 'GitFlic',
  'GitVerse', 'Azure DevOps', 'AWS CodeCommit', 'Forgejo', 'SourceHut', 'Generic',
];
---
<BaseLayout title="Federated Git for enterprises" description="HelixGitpx federates your repositories across every major Git host. One namespace, many hosts, no lock-in.">
  <section class="mx-auto max-w-7xl px-6 pt-16 pb-24 text-center">
    <p class="text-sm font-medium text-primary uppercase tracking-wider">v1.0 is live</p>
    <h1 class="mt-4 text-5xl md:text-6xl font-semibold tracking-tight">
      One namespace.<br /><span class="text-primary">Every Git host.</span>
    </h1>
    <p class="mt-6 max-w-2xl mx-auto text-lg text-slate-600">
      HelixGitpx mirrors your repositories across every major Git provider in real time.
      If GitHub goes down, GitLab, Gitea, and ten others have your code. Enterprise-grade.
      Policy-driven. AI-assisted.
    </p>
    <div class="mt-10 flex justify-center gap-4">
      <a href="/signup" class="rounded bg-primary px-6 py-3 font-medium text-white hover:bg-blue-700">Start free</a>
      <a href="/demo" class="rounded border border-slate-300 px-6 py-3 font-medium hover:border-primary hover:text-primary">Book a demo</a>
    </div>
    <p class="mt-6 text-xs text-slate-500">SOC 2 · ISO 27001 gap audited · Apache-2.0 open source</p>
  </section>

  <section class="bg-slate-50 border-y border-slate-200">
    <div class="mx-auto max-w-7xl px-6 py-12">
      <h2 class="text-center text-sm font-medium text-slate-500 uppercase tracking-wider">12 providers, one workflow</h2>
      <div class="mt-6 grid grid-cols-3 md:grid-cols-6 gap-6 items-center text-center text-slate-600 font-medium">
        {providers.map((p) => <div>{p}</div>)}
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-7xl px-6 py-24 grid md:grid-cols-3 gap-8">
    <div class="rounded-2xl border border-slate-200 p-8">
      <div class="h-10 w-10 rounded bg-primary/10 flex items-center justify-center text-primary font-semibold">1</div>
      <h3 class="mt-4 text-xl font-semibold">Federation without lock-in</h3>
      <p class="mt-2 text-slate-600">Push once; HelixGitpx mirrors to every bound host with audit trails and signed commits preserved.</p>
    </div>
    <div class="rounded-2xl border border-slate-200 p-8">
      <div class="h-10 w-10 rounded bg-primary/10 flex items-center justify-center text-primary font-semibold">2</div>
      <h3 class="mt-4 text-xl font-semibold">AI-assisted code flow</h3>
      <p class="mt-2 text-slate-600">PR summaries, conflict proposals, ChatOps, code and semantic search. Self-hosted LLM or cloud.</p>
    </div>
    <div class="rounded-2xl border border-slate-200 p-8">
      <div class="h-10 w-10 rounded bg-primary/10 flex items-center justify-center text-primary font-semibold">3</div>
      <h3 class="mt-4 text-xl font-semibold">Policy as code</h3>
      <p class="mt-2 text-slate-600">OPA Rego bundles, signed, diff-reviewed, rollback-ready. Every enforcement point is auditable.</p>
    </div>
  </section>

  <section class="mx-auto max-w-7xl px-6 py-24 text-center">
    <h2 class="text-4xl font-semibold">Ready when your industry is</h2>
    <p class="mt-4 text-slate-600 max-w-2xl mx-auto">
      Multi-region active-passive with 5-minute RTO. Quarterly DR drills. SOC 2 Type I evidence
      collected at GA. ISO 27001 gap analysis complete. Bug bounty live.
    </p>
    <div class="mt-10 grid md:grid-cols-4 gap-6 text-left">
      <div class="rounded-lg border border-slate-200 p-6">
        <div class="text-3xl font-semibold">99.99%</div>
        <div class="text-sm text-slate-600">SLO target</div>
      </div>
      <div class="rounded-lg border border-slate-200 p-6">
        <div class="text-3xl font-semibold">≤ 5 min</div>
        <div class="text-sm text-slate-600">DR RTO</div>
      </div>
      <div class="rounded-lg border border-slate-200 p-6">
        <div class="text-3xl font-semibold">≤ 30 s</div>
        <div class="text-sm text-slate-600">DR RPO</div>
      </div>
      <div class="rounded-lg border border-slate-200 p-6">
        <div class="text-3xl font-semibold">Apache-2.0</div>
        <div class="text-sm text-slate-600">Code licence</div>
      </div>
    </div>
  </section>

  <section class="bg-secondary text-white">
    <div class="mx-auto max-w-7xl px-6 py-20 text-center">
      <h2 class="text-4xl font-semibold">Your code. Your provider choice. Your policy.</h2>
      <p class="mt-4 text-slate-300">Start free in 90 seconds. No credit card. Migrate later — or never.</p>
      <a href="/signup" class="mt-8 inline-block rounded bg-white px-6 py-3 font-medium text-secondary hover:bg-slate-100">Start free</a>
    </div>
  </section>
</BaseLayout>
