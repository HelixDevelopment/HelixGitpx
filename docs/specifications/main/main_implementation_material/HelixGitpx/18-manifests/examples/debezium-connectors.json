{
  "_comment": "Debezium connectors for the HelixGitpx outbox pattern. Apply via Strimzi KafkaConnector CRs or Kafka Connect REST API. Each service has its own outbox table; this file enumerates all of them.",
  "config_reference": {
    "plugin": "io.debezium.connector.postgresql.PostgresConnector",
    "snapshot.mode": "initial_only",
    "tombstones.on.delete": "false",
    "key.converter": "io.confluent.connect.avro.AvroConverter",
    "value.converter": "io.confluent.connect.avro.AvroConverter",
    "schema.registry.url": "http://karapace.kafka.svc.cluster.local:8081"
  },
  "connectors": [
    {
      "name": "helixgitpx-auth-outbox",
      "config": {
        "connector.class": "io.debezium.connector.postgresql.PostgresConnector",
        "tasks.max": "1",
        "database.hostname": "postgres-rw.data.svc.cluster.local",
        "database.port": "5432",
        "database.user": "${secrets:debezium-auth-pg-user}",
        "database.password": "${secrets:debezium-auth-pg-password}",
        "database.dbname": "helixgitpx",
        "database.server.name": "helixgitpx-auth",
        "publication.name": "dbz_auth_outbox",
        "slot.name": "dbz_auth_outbox",
        "plugin.name": "pgoutput",
        "snapshot.mode": "never",
        "table.include.list": "auth.event_outbox",
        "transforms": "outbox",
        "transforms.outbox.type": "io.debezium.transforms.outbox.EventRouter",
        "transforms.outbox.route.by.field": "aggregate_kind",
        "transforms.outbox.table.field.event.id": "id",
        "transforms.outbox.table.field.event.key": "aggregate_id",
        "transforms.outbox.table.field.event.type": "event_type",
        "transforms.outbox.table.field.event.payload": "payload",
        "transforms.outbox.table.field.event.timestamp": "occurred_at",
        "transforms.outbox.table.fields.additional.placement": "headers:envelope,schema_version:schema_version",
        "route.topic.replacement": "helixgitpx.auth.${routedByValue}",
        "heartbeat.interval.ms": "5000",
        "heartbeat.action.query": "INSERT INTO auth.dbz_heartbeat(ts) VALUES(now()) ON CONFLICT DO NOTHING",
        "schema.history.internal.kafka.bootstrap.servers": "kafka-kafka-bootstrap.kafka:9092",
        "schema.history.internal.kafka.topic": "dbz.helixgitpx.auth.schemahistory",
        "signal.data.collection": "auth.dbz_signals",
        "decimal.handling.mode": "precise",
        "time.precision.mode": "adaptive_time_microseconds",
        "producer.override.compression.type": "zstd",
        "producer.override.acks": "all",
        "producer.override.enable.idempotence": "true",
        "errors.tolerance": "all",
        "errors.deadletterqueue.topic.name": "helixgitpx.auth.dlq",
        "errors.deadletterqueue.context.headers.enable": "true",
        "errors.log.enable": "true",
        "errors.log.include.messages": "false"
      }
    },

    {
      "name": "helixgitpx-repo-outbox",
      "config": {
        "connector.class": "io.debezium.connector.postgresql.PostgresConnector",
        "tasks.max": "3",
        "database.hostname": "postgres-rw.data.svc.cluster.local",
        "database.port": "5432",
        "database.user": "${secrets:debezium-repo-pg-user}",
        "database.password": "${secrets:debezium-repo-pg-password}",
        "database.dbname": "helixgitpx",
        "database.server.name": "helixgitpx-repo",
        "publication.name": "dbz_repo_outbox",
        "slot.name": "dbz_repo_outbox",
        "plugin.name": "pgoutput",
        "snapshot.mode": "never",
        "table.include.list": "repo.event_outbox,org.event_outbox,upstream.event_outbox",
        "transforms": "outbox",
        "transforms.outbox.type": "io.debezium.transforms.outbox.EventRouter",
        "transforms.outbox.table.field.event.id": "id",
        "transforms.outbox.table.field.event.key": "aggregate_id",
        "transforms.outbox.table.field.event.type": "event_type",
        "transforms.outbox.table.field.event.payload": "payload",
        "transforms.outbox.table.field.event.timestamp": "occurred_at",
        "transforms.outbox.route.by.field": "aggregate_kind",
        "route.topic.replacement": "helixgitpx.repo.${routedByValue}",
        "heartbeat.interval.ms": "5000",
        "producer.override.compression.type": "zstd",
        "producer.override.acks": "all",
        "producer.override.enable.idempotence": "true",
        "errors.tolerance": "all",
        "errors.deadletterqueue.topic.name": "helixgitpx.repo.dlq",
        "_comment": "Higher tasks.max because repo has the highest event volume.",
        "max.batch.size": "16384",
        "max.queue.size": "131072"
      }
    },

    {
      "name": "helixgitpx-conflict-collab-outbox",
      "config": {
        "connector.class": "io.debezium.connector.postgresql.PostgresConnector",
        "tasks.max": "2",
        "database.hostname": "postgres-rw.data.svc.cluster.local",
        "database.port": "5432",
        "database.user": "${secrets:debezium-collab-pg-user}",
        "database.password": "${secrets:debezium-collab-pg-password}",
        "database.dbname": "helixgitpx",
        "database.server.name": "helixgitpx-collab",
        "publication.name": "dbz_collab_outbox",
        "slot.name": "dbz_collab_outbox",
        "plugin.name": "pgoutput",
        "table.include.list": "conflict.event_outbox,collab.event_outbox,ai.event_outbox",
        "transforms": "outbox",
        "transforms.outbox.type": "io.debezium.transforms.outbox.EventRouter",
        "transforms.outbox.route.by.field": "aggregate_kind",
        "route.topic.replacement": "helixgitpx.${routedByValue}",
        "snapshot.mode": "never",
        "heartbeat.interval.ms": "5000",
        "producer.override.compression.type": "zstd",
        "producer.override.acks": "all",
        "producer.override.enable.idempotence": "true",
        "errors.tolerance": "all",
        "errors.deadletterqueue.topic.name": "helixgitpx.collab.dlq"
      }
    },

    {
      "name": "helixgitpx-audit-billing-outbox",
      "config": {
        "connector.class": "io.debezium.connector.postgresql.PostgresConnector",
        "tasks.max": "1",
        "database.hostname": "postgres-rw.data.svc.cluster.local",
        "database.port": "5432",
        "database.user": "${secrets:debezium-audit-pg-user}",
        "database.password": "${secrets:debezium-audit-pg-password}",
        "database.dbname": "helixgitpx",
        "database.server.name": "helixgitpx-audit",
        "publication.name": "dbz_audit_outbox",
        "slot.name": "dbz_audit_outbox",
        "plugin.name": "pgoutput",
        "table.include.list": "audit.event_outbox,billing.event_outbox,notify.event_outbox,policy.event_outbox,sync.event_outbox",
        "transforms": "outbox",
        "transforms.outbox.type": "io.debezium.transforms.outbox.EventRouter",
        "transforms.outbox.route.by.field": "aggregate_kind",
        "route.topic.replacement": "helixgitpx.${routedByValue}",
        "snapshot.mode": "never",
        "heartbeat.interval.ms": "5000",
        "producer.override.compression.type": "zstd",
        "producer.override.acks": "all",
        "producer.override.enable.idempotence": "true",
        "_note": "Audit outbox must never silently drop. Retry forever; DLQ is manual-intervention only.",
        "errors.tolerance": "none"
      }
    }
  ],

  "operational_notes": {
    "slot_monitoring": "Watch `pg_replication_slots.active` + `confirmed_flush_lsn` lag. Orphaned slots bloat WAL; alert on slot_disk > 1GB.",
    "failover": "CNPG promotes a new primary; Debezium auto-reconnects. On first connect to a new primary, validate that slot + publication exist; create if missing via idempotent SQL.",
    "heartbeat": "heartbeat.action.query keeps LSN advancing during quiet periods so slots don't accumulate WAL.",
    "snapshot_mode_never": "We never snapshot — event_outbox is bounded, and we cleanly start from current LSN. Initial loads use separate scripts.",
    "tasks_max": "Each connector task corresponds to a LogMiner / replication stream. Don't over-provision; >1 task only matters when partitioning by table across tasks is enabled.",
    "security": "Credentials come from Vault via External Secrets operator. No long-lived secrets in the connector config.",
    "metrics": "JMX metrics scraped by Prometheus; Grafana dashboard 'Debezium Connector Health' tracks lag, error rate, heartbeat age."
  }
}
