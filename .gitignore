# If you prefer the allow list template instead of the deny list, see community template:
# https://github.com/github/gitignore/blob/main/community/Golang/Go.AllowList.gitignore
#
# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, built with `go test -c`
*.test

# Code coverage profiles and other test artifacts
*.out
coverage.*
*.coverprofile
profile.cov

# Dependency directories (remove the comment below to include it)
# vendor/

# Go workspace file (ignore at root; allow under impl/ and test/)
go.work
go.work.sum
!impl/**/go.work
!impl/**/go.work.sum
!test/go.work
!test/go.work.sum

# env file
.env

# Editor/IDE
# .idea/
# .vscode/

# Web build artifacts
impl/helixgitpx-web/node_modules/
impl/helixgitpx-web/dist/
impl/helixgitpx-web/.angular/
impl/helixgitpx-web/.nx/
impl/helixgitpx-web/coverage/
impl/helixgitpx-web/package-lock.json

# Docs site artifacts
impl/helixgitpx-docs-site/node_modules/
impl/helixgitpx-docs-site/build/
impl/helixgitpx-docs-site/.docusaurus/
impl/helixgitpx-docs-site/package-lock.json

# KMP client build artifacts
impl/helixgitpx-clients/.gradle/
impl/helixgitpx-clients/build/
impl/helixgitpx-clients/**/build/
impl/helixgitpx-clients/**/.gradle/

# Built binaries in source tree
impl/helixgitpx/tools/scaffold/scaffold

# Marketing website build
impl/helixgitpx-website/node_modules/
impl/helixgitpx-website/dist/
impl/helixgitpx-website/package-lock.json
impl/helixgitpx-website/.astro/

# Manual build outputs (regenerate from src/)
docs/manuals/dist/

# Coverage reports (regenerate from tests)
tools/coverage-audit/reports/
